{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BepInEx Mod Manager",
  "version": "1.0.0",
  "identifier": "com.small-lizi.bepinexmodmanager",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BepInEx Mod Manager",
        "width": 900,
        "height": 600,
        "minWidth": 760,
        "minHeight": 500,
        "resizable": true,
        "center": true,
        "decorations": false,
        "shadow": true,
        "label": "main"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
